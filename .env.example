# ============================================================
# tailscale-headless-macos
# Copy to .env and update the values below before running install.sh
# ============================================================

# REQUIRED
# Your Tailscale tailnet domain (MagicDNS suffix)
# Find it with: tailscale dns status --all
TAILNET_DOMAIN=your-tailnet.ts.net

# OPTIONAL
# Set the hostname as it should appear in Tailscale
# If left blank, it will be auto-detected from macOS
TS_HOSTNAME=

# ------------------------------------------------------------
# Advanced (leave as-is unless you know what you're doing)
# ------------------------------------------------------------

BREW_BIN=brew
TAILSCALED_SOCKET=/var/run/tailscaled.socket
TAILSCALED_WAIT_SECONDS=20

ACCEPT_ROUTES=true
ACCEPT_DNS=true
RUN_TAILSCALE_UP=true

TAILSCALE_EXTRA_FLAGS=

REMOVE_BREW_PACKAGE=false

LAUNCHD_LABEL=com.tailscale.tailscaled
LAUNCHD_PLIST=/Library/LaunchDaemons/com.tailscale.tailscaled.plist

STATE_DIR=/var/lib/tailscale
STATE_FILE=/var/lib/tailscale/tailscaled.state

LOG_OUT=/var/log/tailscaled.log
LOG_ERR=/var/log/tailscaled.err
